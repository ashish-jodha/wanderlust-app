<% layout('layouts/boilerplate') %>
<% 
    const pageWrap = "relative flex items-center justify-center min-h-[85vh] py-12 px-4 sm:px-6 lg:px-8 overflow-hidden";
    const bgGlow1 = "absolute top-[-20%] right-[-10%] w-[50%] h-[50%] bg-violet-400/20 blur-[120px] rounded-full pointer-events-none";
    const bgGlow2 = "absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-rose-400/10 blur-[120px] rounded-full pointer-events-none";
    const formCard = "relative w-full max-w-5xl bg-white/80 backdrop-blur-xl rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)] border border-white flex flex-col md:flex-row overflow-hidden";
    const leftPanel = "bg-zinc-900 p-10 md:p-14 md:w-5/12 flex flex-col justify-between relative overflow-hidden text-white";
    const leftDecor = "absolute -bottom-32 -right-32 w-80 h-80 bg-violet-500/40 blur-[80px] rounded-full pointer-events-none";
    const brandBadge = "inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-md border border-white/10 text-sm font-bold text-white w-max mb-12";
    const titleText = "text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight mb-4";
    const subtitleText = "text-zinc-400 text-lg leading-relaxed font-medium";
    const rightPanel = "p-8 md:p-14 md:w-7/12 bg-white space-y-6 group needs-validation flex flex-col justify-center";
    const inputGroup = "flex flex-col relative";
    const labelStyle = "text-[0.8rem] font-bold text-zinc-500 uppercase tracking-widest mb-2 ml-1";
    const inputBase = "peer w-full px-5 py-4 rounded-2xl border-2 border-zinc-100 bg-zinc-50 focus:bg-white focus:border-rose-500 focus:ring-4 focus:ring-rose-500/10 outline-none transition-all duration-300 text-zinc-900 placeholder-zinc-400 group-[.was-validated]:invalid:border-rose-500 group-[.was-validated]:valid:border-green-500 font-semibold text-base shadow-sm";
    const invalidMsg = "hidden text-rose-500 text-xs font-bold mt-2 ml-1 items-center gap-1 group-[.was-validated]:peer-invalid:flex transition-all";
    const validMsg = "hidden text-green-500 text-xs font-bold mt-2 ml-1 items-center gap-1 group-[.was-validated]:peer-valid:flex transition-all";
    const submitWrap = "pt-4 mt-2 flex flex-col gap-4";
    const submitBtn = "w-full bg-zinc-900 hover:bg-rose-500 text-white px-10 py-4 rounded-2xl font-bold shadow-[0_8px_20px_rgb(0,0,0,0.12)] hover:shadow-[0_8px_25px_rgba(244,63,94,0.3)] transition-all duration-300 cursor-pointer text-center text-lg transform hover:-translate-y-1";
    const switchLinkWrap = "text-center text-sm font-medium text-zinc-600 mt-2";
    const switchLink = "text-rose-500 hover:text-rose-600 font-bold hover:underline transition-colors ml-1 text-decoration-none";
%>

<div class="<%= pageWrap %>">
    
    <div class="<%= bgGlow1 %>"></div>
    <div class="<%= bgGlow2 %>"></div>

    <div class="<%= formCard %>">
        
        <div class="<%= leftPanel %>">
            <div>
                <div class="<%= brandBadge %>">
                    <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                    </svg>
                    Join Wanderlust
                </div>
                <h1 class="<%= titleText %>">Start your journey.</h1>
                <p class="<%= subtitleText %>">Create an account to unlock exclusive listings, leave reviews, and host your own extraordinary spaces.</p>
            </div>
            <div class="<%= leftDecor %>"></div>
        </div>

        <form method="POST" action="/signup" novalidate class="<%= rightPanel %>">
            
            <div class="<%= inputGroup %>">
                <label for="username" class="<%= labelStyle %>">Username</label>
                <input type="text" id="username" name="username" placeholder="Choose a unique username" class="<%= inputBase %>" required autofocus>
                <div class="<%= validMsg %>">Looks good!</div>
                <div class="<%= invalidMsg %>">Please provide a valid username.</div>
            </div>

            <div class="<%= inputGroup %>">
                <label for="email" class="<%= labelStyle %>">Email Address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" class="<%= inputBase %>" required>
                <div class="<%= validMsg %>">Looks good!</div>
                <div class="<%= invalidMsg %>">Please provide a valid email address.</div>
            </div>

            <div class="<%= inputGroup %>">
                <label for="password" class="<%= labelStyle %>">Password</label>
                <input type="password" id="password" name="password" placeholder="Create a strong password" class="<%= inputBase %>" required minlength="6">
                <div class="<%= validMsg %>">Looks good!</div>
                <div class="<%= invalidMsg %>">Password must be at least 6 characters long.</div>
            </div>

            <div class="<%= submitWrap %>">
                <button type="submit" class="<%= submitBtn %>">Create Account</button>
                <div class="<%= switchLinkWrap %>">
                    Already have an account? <a href="/login" class="<%= switchLink %>">Log in here</a>
                </div>
            </div>

        </form>
    </div>

</div>

<script>
    (() => {
        'use strict';
        const forms = document.querySelectorAll('.needs-validation');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    })();
</script>