<% layout('layouts/boilerplate') %>
<% 
    const pageWrap = "max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 w-full";
    const headerWrap = "mb-8";
    const titleStyle = "text-3xl md:text-4xl font-extrabold text-zinc-900 tracking-tight mb-3";
    const locationBadge = "inline-flex items-center gap-1.5 text-base text-zinc-600 font-medium";
    const imageWrap = "w-full aspect-[4/3] sm:aspect-[16/9] lg:aspect-[21/9] rounded-[2rem] overflow-hidden mb-12 shadow-[0_8px_30px_rgb(0,0,0,0.08)] relative";
    const imageStyle = "w-full h-full object-cover";
    const contentGrid = "grid grid-cols-1 lg:grid-cols-3 gap-12 relative";
    const leftCol = "lg:col-span-2 space-y-10";
    const hostInfoWrap = "flex items-center gap-4 pb-8 border-b border-zinc-200";
    const avatarFallback = "w-12 h-12 bg-zinc-900 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-sm";
    const hostText = "text-xl font-bold text-zinc-900";
    const hostSub = "text-zinc-500 text-sm";
    const descWrap = "prose prose-lg prose-zinc max-w-none text-zinc-700 leading-relaxed";
    const rightCol = "relative";
    const actionCard = "bg-white p-6 sm:p-8 rounded-3xl border border-zinc-200 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.05)] lg:sticky lg:top-28";
    const priceWrap = "flex items-baseline gap-2 mb-6";
    const priceText = "text-3xl font-extrabold text-zinc-900";
    const nightText = "text-lg text-zinc-500 font-medium";
    const btnGroup = "flex flex-col gap-3";
    const editBtn = "w-full bg-zinc-900 hover:bg-zinc-800 text-white text-center px-6 py-4 rounded-xl font-bold shadow-sm hover:shadow-md transition-all text-decoration-none text-lg";
    const deleteForm = "w-full";
    const deleteBtn = "w-full bg-rose-50 hover:bg-rose-500 text-rose-500 hover:text-white border border-rose-100 hover:border-rose-500 text-center px-6 py-4 rounded-xl font-bold transition-all text-lg cursor-pointer";
    const divider = "h-px bg-zinc-200 my-2";
    const reviewSectionTitle = "text-2xl font-extrabold text-zinc-900 mb-6";
    const reviewFormWrap = "bg-zinc-50 p-6 sm:p-8 rounded-3xl border border-zinc-100 shadow-sm";
    const gridTwoCol = "grid grid-cols-1 sm:grid-cols-2 gap-6";
    const inputGroup = "flex flex-col relative";
    const labelStyle = "text-[0.8rem] font-bold text-zinc-500 uppercase tracking-widest mb-2 ml-1";
    const inputBase = "peer w-full px-5 py-4 rounded-2xl border-2 border-zinc-100 bg-white focus:border-zinc-900 focus:ring-4 focus:ring-zinc-900/10 outline-none transition-all duration-300 text-zinc-900 placeholder-zinc-400 group-[.was-validated]:invalid:border-rose-500 group-[.was-validated]:valid:border-green-500 font-semibold text-base shadow-sm";
    const textAreaBase = "peer w-full px-5 py-4 rounded-2xl border-2 border-zinc-100 bg-white focus:border-zinc-900 focus:ring-4 focus:ring-zinc-900/10 outline-none transition-all duration-300 text-zinc-900 placeholder-zinc-400 resize-y min-h-[140px] group-[.was-validated]:invalid:border-rose-500 group-[.was-validated]:valid:border-green-500 font-semibold text-base shadow-sm";
    const invalidMsg = "hidden text-rose-500 text-xs font-bold mt-2 ml-1 items-center gap-1 group-[.was-validated]:peer-invalid:flex transition-all";
    const validMsg = "hidden text-green-500 text-xs font-bold mt-2 ml-1 items-center gap-1 group-[.was-validated]:peer-valid:flex transition-all";
    const reviewSubmitBtn = "mt-6 bg-zinc-900 hover:bg-rose-500 text-white px-8 py-3.5 rounded-2xl font-bold shadow-sm hover:shadow-md transition-all duration-300 cursor-pointer transform hover:-translate-y-0.5 inline-block";
    const reviewsGrid = "grid grid-cols-1 gap-6";
    const reviewCard = "p-6 rounded-3xl border border-zinc-200 bg-white shadow-sm flex flex-col justify-between items-start gap-4 hover:shadow-md transition-shadow w-full";
    const reviewCardHeader = "flex items-start justify-between w-full border-b border-zinc-100 pb-4";
    const reviewAvatar = "w-10 h-10 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center font-bold text-sm shadow-inner shrink-0";
    const reviewName = "font-bold text-zinc-900";
    const reviewDate = "text-xs text-zinc-500 font-medium mt-0.5";
    const reviewStars = "flex items-center gap-1 bg-zinc-900 text-white px-3 py-1 rounded-full text-xs font-bold shadow-sm shrink-0";
    const reviewCommentText = "text-zinc-700 text-base leading-relaxed w-full";
    const reviewDeleteBtn = "text-sm font-bold text-rose-500 hover:text-rose-600 hover:underline transition-colors cursor-pointer bg-transparent border-none p-0 mt-2";
%>

<style>
    .star-rating-interactive { display: flex; flex-direction: row-reverse; justify-content: flex-end; gap: 0.25rem; }
    .star-rating-interactive input { display: none; }
    .star-rating-interactive label { cursor: pointer; color: #e4e4e7; transition: all 0.2s ease; }
    .star-rating-interactive label svg { width: 2.25rem; height: 2.25rem; fill: currentColor; }
    .star-rating-interactive input:checked ~ label { color: #facc15; }
    .star-rating-interactive label:hover, .star-rating-interactive label:hover ~ label { color: #facc15; transform: scale(1.1); }
</style>

<div class="<%= pageWrap %>">
    
    <div class="<%= headerWrap %>">
        <h1 class="<%= titleStyle %>"><%= Hotel.name %></h1>
        <div class="<%= locationBadge %>">
            <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.243-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <%= Hotel.location %>, <%= Hotel.country %>
        </div>
    </div>

    <div class="<%= imageWrap %>">
        <img src="<%= Hotel.image || 'https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=1200' %>" 
             alt="<%= Hotel.name %>" 
             class="<%= imageStyle %>">
    </div>

    <div class="<%= contentGrid %>">
        
        <div class="<%= leftCol %>">
            <div class="<%= hostInfoWrap %>">
                <div class="<%= avatarFallback %>">
                    <%= Hotel.name.charAt(0).toUpperCase() %>
                </div>
                <div>
                    <h2 class="<%= hostText %>">Hosted by Wanderlust</h2>
                    <p class="<%= hostSub %>">Superhost &middot; Dedicated to providing great stays</p>
                </div>
            </div>
            
            <div class="<%= descWrap %>">
                <p><%= Hotel.description %></p>
            </div>

            <div class="<%= divider %>"></div>

            <div class="<%= reviewFormWrap %>">
                <h3 class="<%= reviewSectionTitle %>">Leave a Review</h3>
                <form method="POST" action="/listings/<%= Hotel._id %>/reviews" novalidate class="group needs-validation">
                    <div class="<%= gridTwoCol %>">
                        
                        <div class="<%= inputGroup %>">
                            <label for="name" class="<%= labelStyle %>">Your Name</label>
                            <input type="text" id="name" name="review[name]" placeholder="John Doe" class="<%= inputBase %>" required>
                            <div class="<%= validMsg %>">Looks good!</div>
                            <div class="<%= invalidMsg %>">Name is required.</div>
                        </div>
                        
                        <div class="<%= inputGroup %>">
                            <label class="<%= labelStyle %>">Rating</label>
                            <div class="star-rating-interactive mt-2">
                                <input type="radio" id="rate5" name="review[rating]" value="5" />
                                <label for="rate5" title="5 stars"><svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></label>
                                <input type="radio" id="rate4" name="review[rating]" value="4" />
                                <label for="rate4" title="4 stars"><svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></label>
                                <input type="radio" id="rate3" name="review[rating]" value="3" />
                                <label for="rate3" title="3 stars"><svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></label>
                                <input type="radio" id="rate2" name="review[rating]" value="2" />
                                <label for="rate2" title="2 stars"><svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></label>
                                <input type="radio" id="rate1" name="review[rating]" value="1" checked />
                                <label for="rate1" title="1 star"><svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg></label>
                            </div>
                        </div>

                        <div class="<%= inputGroup %> sm:col-span-2">
                            <label for="comment" class="<%= labelStyle %>">Your Review</label>
                            <textarea id="comment" name="review[comment]" placeholder="Share details of your own experience at this place..." class="<%= textAreaBase %>" required></textarea>
                            <div class="<%= validMsg %>">Looks good!</div>
                            <div class="<%= invalidMsg %>">Please write a review comment.</div>
                        </div>

                    </div>
                    <button type="submit" class="<%= reviewSubmitBtn %>">Submit Review</button>
                </form>
            </div>

            <div class="<%= divider %>"></div>

            <div>
                <h3 class="<%= reviewSectionTitle %>">Guest Reviews</h3>
                
                <% if(Hotel.reviews && Hotel.reviews.length > 0) { %>
                    <div class="<%= reviewsGrid %>">
                        <% for(let review of Hotel.reviews) { %>
                            <div class="<%= reviewCard %>">
                                
                                <div class="<%= reviewCardHeader %>">
                                    <div class="flex items-center gap-3">
                                        <div class="<%= reviewAvatar %>">
                                            <%= review.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <h4 class="<%= reviewName %>"><%= review.name %></h4>
                                            <p class="<%= reviewDate %>"><%= review.date.toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                                        </div>
                                    </div>
                                    <div class="<%= reviewStars %>">
                                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                                        <%= review.rating %>
                                    </div>
                                </div>

                                <p class="<%= reviewCommentText %>"><%= review.comment %></p>

                                <form method="POST" action="/listings/<%= Hotel._id %>/reviews/<%= review._id %>?_method=DELETE">
                                    <button type="submit" class="<%= reviewDeleteBtn %>">Delete Review</button>
                                </form>

                            </div>
                        <% } %>
                    </div>
                <% } else { %>
                    <p class="text-zinc-500 bg-zinc-50 p-6 rounded-2xl border border-dashed border-zinc-300 text-center">No reviews yet. Be the first to share your experience!</p>
                <% } %>
            </div>

        </div>

        <div class="<%= rightCol %>">
            <div class="<%= actionCard %>">
                <div class="<%= priceWrap %>">
                    <span class="<%= priceText %>">&#8377; <%= Hotel.price.toLocaleString('en-IN') %></span>
                    <span class="<%= nightText %>">/ night</span>
                </div>
                
                <div class="<%= btnGroup %>">
                    <a href="/listings/<%= Hotel._id %>/edit" class="<%= editBtn %>">Edit Listing</a>
                    
                    <form method="POST" action="/listings/<%= Hotel._id %>?_method=DELETE" class="<%= deleteForm %>">
                        <button type="submit" class="<%= deleteBtn %>">Delete Listing</button>
                    </form>
                </div>
            </div>
        </div>

    </div>

</div>

<script>
    (() => {
        'use strict';
        const forms = document.querySelectorAll('.needs-validation');
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }
                form.classList.add('was-validated');
            }, false);
        });
    })();
</script>