<% 
    const footerContainer = "bg-zinc-50 border-t border-zinc-200 mt-auto";
    const footerWrapper = "max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8";
    const footerLayout = "flex flex-col md:flex-row justify-between items-center gap-4";
    const copyText = "text-zinc-500 text-sm text-center"; 
    const linksLayout = "flex flex-wrap justify-center gap-4 sm:gap-6"; 
    const linkItem = "text-sm text-zinc-500 hover:text-rose-500 font-medium transition-colors duration-200";
%>

<footer class="<%= footerContainer %>">
    <div class="<%= footerWrapper %>">
        <div class="<%= footerLayout %>">
            
            <div class="<%= copyText %>">
                &copy; 2026 Wanderlust Private Limited. All rights reserved.
            </div>

            <div class="<%= linksLayout %>">
                <a href="#" class="<%= linkItem %>">Privacy Policy</a>
                <a href="#" class="<%= linkItem %>">Terms of Service</a>
                <a href="#" class="<%= linkItem %>">Support</a>
            </div>

        </div>
    </div>
</footer>